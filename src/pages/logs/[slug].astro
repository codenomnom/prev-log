---
import { getCollection } from "astro:content";
import Layout from "../../layouts/SingleLogLayout.astro";

export async function getStaticPaths() {
  const logs = await getCollection("logs");

  return logs.map((log) => ({
    params: { slug: log.id },
    props: { log },
  }));
}

const props = Astro.props;
---

<Layout {...props} />
